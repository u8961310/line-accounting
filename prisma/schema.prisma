generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String         @id @default(cuid())
  lineUserId     String         @unique
  displayName    String
  createdAt      DateTime       @default(now())
  transactions   Transaction[]
  bankBalances   BankBalance[]
  loans          Loan[]
  creditCards    CreditCard[]
  budgets              Budget[]
  mealBudgets          MealBudget[]
  fixedExpenses        FixedExpense[]
  netWorthSnapshots    NetWorthSnapshot[]
  financialGoals       FinancialGoal[]
  healthScoreSnapshots HealthScoreSnapshot[]
  userCategories       UserCategory[]
  tasks                Task[]
  settings             UserSettings?
  streak               UserStreak?
  categoryRules        CategoryRule[]
  personalDebts        PersonalDebt[]
  events               Event[]
  aiInsights           AiInsight[]
}

model Budget {
  id           String   @id @default(cuid())
  userId       String
  category     String   // 飲食 / 交通 / 娛樂 / 購物 / 醫療 / 其他
  amount       Decimal  @db.Decimal(12, 2)
  carryoverPct Int      @default(0)  // 0–100：上月剩餘結轉百分比
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
}

model MealBudget {
  id        String   @id @default(cuid())
  userId    String
  mealType  String   // "breakfast" | "lunch" | "dinner"
  amount    Decimal  @db.Decimal(12, 2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mealType])
  @@index([userId])
}

model BankBalance {
  id          String   @id @default(cuid())
  userId      String
  source      String
  balance     Decimal  @db.Decimal(12, 2)
  asOfDate    DateTime
  updatedAt   DateTime @updatedAt
  alias       String?           // 自訂別名，如「緊急備用金」「旅遊基金」
  savingsGoal Decimal? @db.Decimal(12, 2)  // 儲蓄目標金額

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, source])
}

model Transaction {
  id             String   @id @default(cuid())
  userId         String
  date           DateTime
  amount         Decimal  @db.Decimal(12, 2)
  category       String
  type           String   // 收入 | 支出
  note           String   @default("")
  source         String   // line | tbank | cathay_bank | esun_bank | ctbc_bank | cathay_cc | esun_cc | ctbc_cc | taishin_cc
  incomeSource   String?  // salary / freelance / bonus / transfer（僅 type=收入 時使用）
  mood           String?  // 必要 | 衝動 | 計畫
  mealType       String?  // "breakfast" | "lunch" | "dinner"，僅飲食類有值
  notionPageId   String?
  transferPairId String?  // 轉帳配對：指向另一筆 Transaction 的 id
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, amount, source])
  @@index([userId])
  @@index([date])
  @@index([userId, date, mealType])
}

model Loan {
  id                 String        @id @default(cuid())
  userId             String
  name               String
  lender             String
  type               String        // 個人信貸 / 房貸 / 車貸 / 分期 / 民間
  originalPrincipal  Decimal       @db.Decimal(12, 2)
  remainingPrincipal Decimal       @db.Decimal(12, 2)
  interestRate       Decimal       @db.Decimal(8, 4)  // annual %, e.g. 9.88
  paymentDay         Int?          // day of month 1-31
  endDate            DateTime?
  status             String        @default("active")  // active / paid_off
  note               String        @default("")
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments LoanPayment[]
}

model LoanPayment {
  id                 String   @id @default(cuid())
  loanId             String
  paymentDate        DateTime
  principalPaid      Decimal  @db.Decimal(12, 2)
  interestPaid       Decimal  @db.Decimal(12, 2)
  totalPaid          Decimal  @db.Decimal(12, 2)
  remainingPrincipal Decimal  @db.Decimal(12, 2)
  note               String   @default("")
  createdAt          DateTime @default(now())

  loan Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)
}

model CreditCard {
  id             String           @id @default(cuid())
  userId         String
  name           String
  bank           String
  creditLimit    Decimal?         @db.Decimal(12, 2)
  statementDay   Int?
  dueDay         Int?
  currentBalance         Decimal  @default(0) @db.Decimal(12, 2)
  installmentOutstanding Decimal  @default(0) @db.Decimal(12, 2)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  user  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  bills CreditCardBill[]
}

model CreditCardBill {
  id             String    @id @default(cuid())
  creditCardId   String
  billingMonth   String    // "2026-03"
  totalAmount    Decimal   @db.Decimal(12, 2)
  minimumPayment Decimal?  @db.Decimal(12, 2)
  dueDate        DateTime
  paidAmount     Decimal   @default(0) @db.Decimal(12, 2)
  paidDate       DateTime?
  status         String    @default("unpaid")  // unpaid / paid / partial
  createdAt      DateTime  @default(now())

  creditCard CreditCard @relation(fields: [creditCardId], references: [id], onDelete: Cascade)
}

model FixedExpense {
  id         String   @id @default(cuid())
  userId     String
  name       String            // 名稱，如「房租」「Netflix」
  amount     Decimal  @db.Decimal(12, 2)
  category   String   @default("居住")
  dayOfMonth Int?              // 每月幾號扣款（選填，1-31）
  note       String   @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PayeeMapping {
  id        String   @id @default(cuid())
  pattern   String   @unique  // 比對 note 的子字串，如 "807-001360"
  label     String            // 顯示名稱，如 "房租"
  category  String   @default("")  // 選填：覆蓋分類
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FinancialGoal {
  id            String    @id @default(cuid())
  userId        String
  name          String
  targetAmount  Decimal   @db.Decimal(12, 2)
  savedAmount   Decimal   @default(0) @db.Decimal(12, 2)
  linkedSource  String?   // 連結帳戶 source（如 "esun_bank"），連結後已存金額自動同步
  deadline      DateTime?
  emoji         String    @default("🎯")
  note          String    @default("")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NetWorthSnapshot {
  id        String   @id @default(cuid())
  userId    String
  month     String   // "2026-04"
  netWorth  Decimal  @db.Decimal(12, 2)
  assets    Decimal  @db.Decimal(12, 2)
  debt      Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
  @@index([userId])
}

model AiInsight {
  id          String   @id @default(cuid())
  userId      String
  month       String   // "2026-04"
  insight     String   @db.Text
  meta        Json     // totalIncome / totalExpense / savingRate / overBudgetCount
  chartUrls   Json?    // { donut, bar }
  source      String   @default("cron") // "cron" | "ondemand" | "backfill"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
  @@index([userId])
}

model HealthScoreSnapshot {
  id              String   @id @default(cuid())
  userId          String
  month           String   // "2026-04"
  score           Int
  savingsScore    Int
  debtScore       Int
  budgetScore     Int
  savingsRate     Float
  debtRatio       Float
  budgetAdherence Float
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
  @@index([userId])
}

model UserCategory {
  id        String   @id @default(cuid())
  userId    String
  name      String
  type      String   @default("both") // "expense" | "income" | "both"
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
}


// ── 人生管理：任務 ────────────────────────────────────────────────────────────

model Task {
  id        String    @id @default(cuid())
  userId    String
  title     String
  dueDate   DateTime?
  dueTime   String    @default("")      // HH:MM 台灣時間，空字串 = 無指定時間
  priority  String    @default("mid")   // high | mid | low
  status    String    @default("open")  // open | done
  category  String    @default("其他")  // 工作 | 生活 | 財務 | 其他
  note      String    @default("")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
  @@index([dueDate])
}

model UserSettings {
  id                    String   @id @default(cuid())
  userId                String   @unique
  expenseAlertThreshold Int      @default(3000)
  incomeAlertThreshold  Int      @default(10000)
  balanceAlertThreshold Int      @default(5000)
  hourlyRate            Int?     // 時薪（NT$），用於支出購買力換算
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserStreak {
  id              String    @id @default(cuid())
  userId          String    @unique
  currentStreak   Int       @default(0)
  longestStreak   Int       @default(0)
  lastRecordDate  String?   // YYYY-MM-DD，台灣時間
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DuplicateDismissal {
  id             String   @id @default(cuid())
  transactionAId String
  transactionBId String
  createdAt      DateTime @default(now())

  @@unique([transactionAId, transactionBId])
  @@index([transactionAId])
  @@index([transactionBId])
}

model CategoryRule {
  id          String    @id @default(cuid())
  userId      String
  keyword     String    // note 含此字串時套用
  category    String
  source      String?   // null = 所有來源；指定則只套用該來源
  hitCount    Int       @default(0)
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, keyword])
  @@index([userId])
}

model PersonalDebt {
  id            String    @id @default(cuid())
  userId        String
  counterparty  String    // 對象姓名
  direction     String    // "owed_to_me" | "i_owe"
  amount        Decimal   @db.Decimal(12, 2)
  note          String    @default("")
  dueDate       DateTime?
  settledAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ── 人生管理：活動 ────────────────────────────────────────────────────────────

model Event {
  id              String    @id @default(cuid())
  userId          String
  title           String
  startAt         DateTime  // 活動開始時間（UTC）
  endAt           DateTime? // 活動結束時間（UTC），選填
  location        String    @default("")
  link            String    @default("")   // 線上會議連結
  speakers        String    @default("")   // 講者（逗號分隔）
  description     String    @default("")
  reminderMinutes Int       @default(60)   // 活動前幾分鐘提醒
  reminded        Boolean   @default(false)
  cronId          String?   // Cronicle 提醒事件 ID
  googleEventId   String?   // Google Calendar event ID，有值代表從 GCal 同步來
  isAllDay        Boolean   @default(false) // 全天事件
  status          String    @default("confirmed") // confirmed | cancelled
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([startAt])
  @@index([userId, startAt, title])
  @@index([googleEventId])
}

model AuditLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  action    String   // mcp_call | csv_import | pdf_import
  tool      String?  // MCP 工具名稱；匯入時為 source 代碼
  params    Json?    // 輸入參數（已過濾敏感資訊）
  summary   Json?    // 結果摘要（匯入筆數等）
  status    String   @default("success")  // success | error
  errorMsg  String?

  @@index([createdAt])
  @@index([action])
}
